if SHIELD_APOLLOSP3_RIGHT #ここを変えてセントラル側に問題のコードを移行

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "ApolloSP3"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif

if SHIELD_APOLLOSP3_LEFT || SHIELD_APOLLOSP3_RIGHT

config ZMK_SPLIT
    default y

endif

# Input Device(pmw3610)のためのコンフィグ
if SHIELD_APOLLOSP3_RIGHT

# Other settings

config ZMK_POINTING
    default y

# Assuming pointing device uses SPI
config SPI
    default y

endif
